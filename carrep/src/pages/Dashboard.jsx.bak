      else if (['?쇰컮', '?쒖뒪', '誘몃?', '留덉슫??, '??댁뼱', '?쇰씪??].some(k => itemName.includes(k))) category = '?꾧?怨?
      else if (['誘몄뀡', '援щ룞'].some(k => itemName.includes(k))) category = '援щ룞怨?
      else if (['釉뚮젅?댄겕', '?⑤뱶'].some(k => itemName.includes(k))) category = '?쒕룞怨?
      else if (['議고뼢', '踰⑦듃', '?먰솕'].some(k => itemName.includes(k))) category = '議고뼢怨?
      const newRepair = {
