{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "regions": ["icn1"]
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,OPTIONS,PATCH,DELETE,POST,PUT" },
        { "key": "Access-Control-Allow-Headers", "value": "X-CSRF-Token, X-Requested-With, Accept, Accept-Version, Content-Length, Content-MD5, Content-Type, Date, X-Api-Version, Range" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/rss/batch",
      "destination": "/api/rss/batch.js"
    },
    {
      "source": "/api/rss",
      "destination": "/api/rss.js"
    },
    {
      "source": "/api/youtube/live",
      "destination": "/api/youtube/live.js"
    },
    {
      "source": "/api/jtbc",
      "destination": "/api/jtbc.js"
    }
  ]
}
